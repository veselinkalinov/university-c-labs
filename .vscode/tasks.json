{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Active C File",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "New-Item -ItemType Directory -Force \"$env:LOCALAPPDATA/BPE\" | Out-Null; gcc '${file}' -g -o \"$env:LOCALAPPDATA/BPE/active.exe\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Run Active C File",
            "type": "shell",
            "dependsOn": "Build Active C File",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-Command",
                "& \"$env:LOCALAPPDATA/BPE/active.exe\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        }
    ]
}
